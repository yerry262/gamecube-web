+/// In-memory replacement for backing files on wasm: the browser has no
+/// filesystem, so backings live in a thread-local store keyed by path,
+/// with a version counter the host polls to know when to persist
+/// (e.g. to IndexedDB).
+#[cfg(target_arch = "wasm32")]
+pub mod wasm_backing {
+    use std::cell::{Cell, RefCell};
+    use std::collections::HashMap;
+
+    thread_local! {
+        static STORE: RefCell<HashMap<String, Vec<u8>>> = RefCell::new(HashMap::new());
+        static VERSION: Cell<u32> = const { Cell::new(0) };
+    }
+
+    /// Seed a backing (before boot) so `load_backing` finds it.
+    pub fn set(name: &str, bytes: Vec<u8>) {
+        STORE.with(|s| s.borrow_mut().insert(name.to_string(), bytes));
+    }
+
+    /// Snapshot a backing's current contents.
+    pub fn get(name: &str) -> Option<Vec<u8>> {
+        STORE.with(|s| s.borrow().get(name).cloned())
+    }
+
+    /// Bumped every time any backing is persisted; cheap to poll from JS.
+    pub fn version() -> u32 {
+        VERSION.with(|v| v.get())
+    }
+
+    pub(super) fn bump_version() {
+        VERSION.with(|v| v.set(v.get().wrapping_add(1)));
+    }
+}
+
+/// Load a fixed-size backing file into `dst`, leaving `dst` untouched (its
+/// default contents) if the file is missing or the wrong size.
+#[cfg(target_arch = "wasm32")]
+pub fn load_backing(path: &std::path::Path, dst: &mut [u8], label: &str) {
+    match wasm_backing::get(&path.to_string_lossy()) {
+        Some(bytes) if bytes.len() == dst.len() => {
+            dst.copy_from_slice(&bytes);
+            tracing::info!(path = %path.display(), label, "loaded backing from wasm store");
+        }
+        Some(bytes) => tracing::warn!(
+            path = %path.display(),
+            label,
+            got = bytes.len(),
+            expected = dst.len(),
+            "wasm backing size mismatch, using default"
+        ),
+        None => tracing::info!(path = %path.display(), label, "no wasm backing, using default"),
+    }
+}
+
+#[cfg(target_arch = "wasm32")]
+pub fn persist_backing(path: &std::path::Path, data: &[u8], label: &str) {
+    let _ = label;
+    wasm_backing::set(&path.to_string_lossy(), data.to_vec());
+    wasm_backing::bump_version();
+}
