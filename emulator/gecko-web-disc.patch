+
+/// Full analog pad state from JS (touch overlay / Gamepad API). Sticks and
+/// triggers are raw hardware values (0..=255, sticks centered at 128),
+/// `buttons` is the PAD button bitmask. Replaces the whole pad state, so
+/// callers must send every held control each time.
+#[wasm_bindgen]
+pub fn set_pad_state(
+    stick_x: u8,
+    stick_y: u8,
+    substick_x: u8,
+    substick_y: u8,
+    trigger_left: u8,
+    trigger_right: u8,
+    buttons: u16,
+) {
+    PENDING_PAD.with(|pending| {
+        *pending.borrow_mut() = Some(PadStatus {
+            buttons,
+            stick_x,
+            stick_y,
+            substick_x,
+            substick_y,
+            trigger_left,
+            trigger_right,
+            connected: true,
+        });
+    });
+}
