+thread_local! {
+    // Pad state pushed from JS, picked up by the event loop on the next frame.
+    static PENDING_PAD: RefCell<Option<PadStatus>> = const { RefCell::new(None) };
+    // [avg fps, percent of native speed], updated once per rendered frame.
+    static PERF: std::cell::Cell<[f64; 2]> = const { std::cell::Cell::new([0.0, 0.0]) };
